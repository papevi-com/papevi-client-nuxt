{
  "name": "papevi-client-nuxt",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint": "oxlint --vue-plugin --import-plugin --promise-plugin --node-plugin .",
